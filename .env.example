# ==========================================================================
# AUTO VISUAL AI — Environment Configuration
# --------------------------------------------------------------------------
# Copy to `.env` and fill in. Only DATABASE_URL and REDIS_URL are required to
# boot. Every provider below is OPTIONAL — each engine checks for its own key
# at call time, so the app runs with whatever you've configured and reports a
# clear error if you trigger a feature whose key is missing.
# ==========================================================================

# --- Core ---------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
# Internal API base used by the worker to call back into the web app
INTERNAL_API_URL=http://localhost:3000

# --- Database (REQUIRED) ------------------------------------------------
DATABASE_URL=postgresql://ava:ava@localhost:5432/auto_visual_ai?schema=public

# --- Redis / Queue (REQUIRED) -------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Auth: Clerk --------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Payments: Stripe ---------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# --- Storage ------------------------------------------------------------
# "local" (default) stores files on disk served by the app — NO AWS NEEDED.
# "s3" uses AWS S3. Leave blank to auto-detect (s3 if AWS keys set, else local).
STORAGE_DRIVER=local
# Absolute path for local storage (defaults to <repo>/.data/storage)
LOCAL_STORAGE_DIR=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# Public read host (CloudFront distribution or S3 website endpoint)
S3_PUBLIC_URL=
# Optional: use a local S3-compatible endpoint (e.g. MinIO) for dev
S3_ENDPOINT=

# --- LLM / Understanding ------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Which model drives sentence analysis: "claude" | "openai"
UNDERSTANDING_PROVIDER=claude
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o

# --- Transcription: Whisper ---------------------------------------------
# "openai"  -> OpenAI hosted Whisper (uses OPENAI_API_KEY)
# "replicate" -> whisper / whisperx via Replicate (word-level timestamps)
# "local"   -> local whisper.cpp / faster-whisper binary
WHISPER_PROVIDER=openai
WHISPER_MODEL=whisper-1
# Used when WHISPER_PROVIDER=replicate (WhisperX gives word-level timestamps)
REPLICATE_WHISPER_MODEL=victor-upmeet/whisperx
# Used when WHISPER_PROVIDER=local (CLI producing WhisperX-style JSON)
WHISPER_LOCAL_CMD=whisperx

# --- Image Generation ---------------------------------------------------
# Default provider: "flux" | "sdxl" | "openai"
IMAGE_PROVIDER=flux
# fal.ai powers Flux / SDXL by default
FAL_KEY=
# Replicate as an alternative host for Flux / SDXL
REPLICATE_API_TOKEN=

# --- Video Generation ---------------------------------------------------
# Default provider: "runway" | "kling" | "pika"
VIDEO_PROVIDER=runway
RUNWAY_API_KEY=
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
PIKA_API_KEY=

# --- Translation (multi-language captions) ------------------------------
# Defaults to the configured UNDERSTANDING_PROVIDER if unset
TRANSLATION_PROVIDER=

# --- Rendering ----------------------------------------------------------
# Path to ffmpeg/ffprobe binaries (leave blank to use system PATH)
FFMPEG_PATH=
FFPROBE_PATH=
# Minimum acceptable quality score (0-100) before export is allowed
QUALITY_MIN_SCORE=95
# Concurrency for Remotion rendering
REMOTION_CONCURRENCY=4

# --- Worker -------------------------------------------------------------
# Max simultaneous heavy jobs per worker (generation/render)
WORKER_CONCURRENCY=2
